{
  "name": "SentriX SOC Platform",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r backend/requirements.txt",
  "postStartCommand": "python run.py",
  "forwardPorts": [8000, 9000, 9001],
  "portsAttributes": {
    "8000": {
      "label": "SentriX API",
      "onAutoForward": "openBrowser"
    },
    "9000": {
      "label": "TheHive",
      "onAutoForward": "silent"
    },
    "9001": {
      "label": "Cortex",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
